\ProvidesPackage{preamble}

% -----------------------------

%
% layout and typography
%

% paper margins
\usepackage[margin=3cm]{geometry}

% appendix
\usepackage[toc,page]{appendix}

% page header/footer
\usepackage{fancyhdr}

% font encoding
\usepackage[T1]{fontenc, url}
\usepackage[utf8]{inputenc}
\usepackage[english]{babel}
\usepackage{csquotes}

% paragraph typography
\linespread{1.3}
\usepackage{parskip}
\usepackage{setspace}
%\usepackage{microtype} % disabled: requires scalable fonts (cm-super/lmodern)
\usepackage{epigraph}

% heading formats
\usepackage{titlesec}
\titleformat*{\section}{\LARGE\bfseries} % \section heading
\titleformat*{\subsection}{\Large\bfseries} % \subsection heading
\titleformat*{\subsubsection}{\large\bfseries} % \subsubsection heading

% -----------------------------

%
% content enhancement
%

% hyperlinks
\usepackage{hyperref}
\usepackage{url}

% tables
\usepackage{array}
\usepackage{multirow}
\usepackage{makecell}
\usepackage{booktabs}

% math
\usepackage{amsmath, amssymb, amsthm}

% graphics 
\usepackage{color}
\usepackage{xcolor}
\usepackage{adjustbox}
\usepackage{graphicx}

% fixed footnotes to bottom of page
\usepackage[bottom]{footmisc}

% quotes and examples
\usepackage{csquotes}
\theoremstyle{definition}
\newtheorem{exmp}{Example}[section]

% code
\usepackage{listings}

% pdf
\usepackage{pdfpages}

% -----------------------------

%
% references
%
\usepackage[
        backend=bibtex,
        bibstyle=nature,
        citestyle=nature
    ]{biblatex}
\addbibresource{\references}

\def\biblio{
    \clearpage\printbibliography
}

% -----------------------------
% end: preamble
